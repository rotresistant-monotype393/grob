{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Grob",
  "scopeName": "source.grob",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.grob",
          "match": "//.*$"
        },
        {
          "name": "comment.block.grob",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.documentation.grob",
          "match": "///.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.grob",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.grob", "match": "\\\\[ntr\\\\\"']" },
            { "name": "variable.other.interpolated.grob", "match": "\\$\\{[^}]+\\}" }
          ]
        },
        {
          "name": "string.quoted.backtick.grob",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.grob",
          "match": "\\b(if|else|for|in|while|return|break|continue|try|catch|finally|throw|select|case|default|switch)\\b"
        },
        {
          "name": "keyword.declaration.grob",
          "match": "\\b(fn|type|import|param|const|readonly)\\b"
        },
        {
          "name": "constant.language.grob",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.grob",
          "match": "\\b(0x[0-9A-Fa-f][0-9A-Fa-f_]*)|(0b[01][01_]*)|(\\d[\\d_]*)(\\.\\d[\\d_]*)?(e[+-]?\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.grob",
          "match": ":=|=>|\\?\\.|\\.\\.|\\?\\?|[+\\-*/%<>=!&|^~]+"
        }
      ]
    }
  }
}
